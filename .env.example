# =====================================================
# Personal AI OS — environment configuration
# Copy this file to `.env` and fill in real values.
# =====================================================

# --- LLM (Google Gemini) ---
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Recommended: gemini-2.0-flash (free tier, fast).
# Alternative: gemini-2.5-flash, gemini-2.5-pro (smarter, paid).
GEMINI_MODEL=gemini-2.0-flash

# --- Google Sheets ---
# Just the alphanumeric chunk between /d/ and /edit in the sheet URL.
GOOGLE_SHEET_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz0123456789
# Worksheet/tab name where tasks will be appended.
GOOGLE_SHEET_TAB=Tasks

# --- Gmail polling ---
# Seconds between Gmail polls. 300 = 5 minutes.
POLLING_INTERVAL=300
# Standard Gmail search syntax.
GMAIL_QUERY_FILTER=is:unread newer_than:2d -category:promotions -category:social

# --- Meeting / audio capture ---
# Length of each audio chunk before transcription.
AUDIO_CHUNK_MINUTES=2
# 16000 is recommended for Whisper.
AUDIO_SAMPLE_RATE=16000
# Use the system default mic if blank, otherwise the device index from `python -m sounddevice`.
AUDIO_INPUT_DEVICE=
# Set to `false` to disable audio capture entirely (e.g. on a server).
ENABLE_MEETING_CAPTURE=true

# --- Faster-Whisper ---
# tiny | base | small | medium | large-v3
WHISPER_MODEL=base
# cpu | cuda
WHISPER_DEVICE=cpu
# int8 (low RAM) | int8_float16 | float16 | float32
WHISPER_COMPUTE_TYPE=int8
# auto-detects, or set to `en`, `hi`, etc.
WHISPER_LANGUAGE=

# --- Storage paths ---
DATABASE_PATH=./data/personal_ai_os.db
AUDIO_CHUNKS_DIR=./data/audio_chunks
TRANSCRIPTS_DIR=./data/transcripts
LOGS_DIR=./logs

# --- Google OAuth (for Gmail + Sheets, separate from Gemini key) ---
GOOGLE_CREDENTIALS_PATH=./credentials.json
GOOGLE_TOKEN_PATH=./token.json

# --- Logging ---
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# --- Daily summary ---
# Local hour (0-23) at which the daily strategic summary is generated.
DAILY_SUMMARY_HOUR=21
=======
# --- Google Sheet ---
# The ID is the long string between /d/ and /edit in the spreadsheet URL.
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Worksheet (tab) name within the spreadsheet. Created automatically if missing.
GOOGLE_SHEET_TAB=Tasks

# Path to a Google service-account JSON key file with edit access to the sheet.
GOOGLE_CREDENTIALS=./credentials.json

# --- Gmail OAuth ---
# Path to the OAuth client secrets JSON downloaded from Google Cloud Console
# (OAuth 2.0 Client ID, type "Desktop app").
GMAIL_OAUTH_CLIENT=./client_secret.json

# Where the cached user token is stored after the first authorization.
GMAIL_TOKEN_PATH=./token.json

# Gmail search query used to fetch candidate messages each tick.
# Default: unread inbox messages from the last day.
GMAIL_QUERY=is:unread in:inbox newer_than:1d

# Maximum number of messages fetched per polling cycle.
GMAIL_MAX_RESULTS=25

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-opus-4-5

# --- Scheduling ---
POLL_INTERVAL_MINUTES=5

# --- Storage ---
SQLITE_PATH=./data/email_intel.db

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=./email_intelligence.log
