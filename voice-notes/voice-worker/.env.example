# Voice-worker environment. Copy to .env and fill in.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Service-role key (Project Settings > API). Trusted backend only — never ship to a client.
SUPABASE_SERVICE_ROLE_KEY=
STORAGE_BUCKET=voice-notes

# worker now polls AssemblyAI for transcript completion
ASSEMBLYAI_API_KEY=
# optional: enables Gemini smart tagging (title/summary/tags/meeting)
GEMINI_API_KEY=

# matching sensitivity (cosine similarity on unit-norm ECAPA embeddings)
SIM_HIGH=0.78
SIM_LOW=0.62

POLL_SECONDS=15
SELF_NAME=Anchit
VOICEPRINT_DEVICE=cpu
